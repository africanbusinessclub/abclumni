# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=abclumni
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=abclumni

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=4000
# Must match the public URL of your server (no trailing slash)
CORS_ORIGIN=https://yourdomain.com
DATABASE_URL=postgresql://abclumni:replace-with-a-strong-password@db:5432/abclumni?schema=public
JWT_SECRET=replace-with-a-64-char-random-string
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
SEED_MEMBER_PASSWORD=replace-with-a-strong-member-password
